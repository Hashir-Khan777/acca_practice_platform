# ==========================================
# Accountly AI PRACTICE PLATFORM - ENVIRONMENT SECRETS
# ==========================================

# 1. DATABASE CONFIGURATION
# MongoDB Atlas connection string. Fallback to local MongoDB in development.
MONGODB_URI=

# 2. AUTHENTICATION SECRETS
# Random secure strings for JWT token signing.
JWT_SECRET=
JWT_REFRESH_SECRET=

# 3. AI COMPONENT CREDENTIALS
# Required for live Gemini AI API quiz generation calls.
GEMINI_API_KEY=

# 4. EMAIL SMTP DISPATCH (NodeMailer)
# Leave blank to fallback to dynamic local Ethereal testing email boxes automatically.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 5. GOOGLE IDENTITY SIGN-IN OAUTH
# Public client ID for browser GIS script initialization
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
